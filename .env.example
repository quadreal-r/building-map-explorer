# Copy to .env.local for local development
VITE_SUPABASE_URL=supabase_url
VITE_SUPABASE_ANON_KEY=supabase_anon_key
VITE_GOOGLE_MAPS_API_KEY=google_maps_api_key
VITE_GOOGLE_MAPS_MAP_ID=google_maps_map_id

# Cloudflare R2 — public CDN base for RTU pictures (production + local dev against R2)
# Example: https://pub-xxxx.r2.dev/ or https://pictures.yourdomain.com/
VITE_RTU_PICTURES_BASE_URL=

# Server-side only (apply-deploy-bundle, upload-rtu-pictures-r2, GitHub Actions)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_KEY_PREFIX=
