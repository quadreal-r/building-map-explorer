{
  "name": "building-map-explorer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:onedrive": "scripts\\start-dev.cmd",
    "dev:window": "scripts\\start-dev-window.cmd",
    "dev:persistent": "scripts\\start-dev-persistent.cmd",
    "dev:restart": "scripts\\restart-dev.cmd",
    "build": "tsc -b && vite build && npm run build:portable",
    "build:portable": "node scripts/build-portable-template.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "extract": "tsx scripts/extract.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "apply-deploy-bundle": "node scripts/apply-deploy-bundle.mjs",
    "upload-rtu-pictures-r2": "node scripts/upload-rtu-pictures-r2.mjs",
    "upload-rtu-documents-r2": "node scripts/upload-rtu-documents-r2.mjs",
    "sync-rtu-pictures-r2": "node scripts/sync-rtu-pictures-r2.mjs",
    "upload-rtu-picture-cloud-aliases": "node scripts/upload-rtu-picture-cloud-aliases.mjs",
    "upload-json-to-r2": "node scripts/upload-json-to-r2.mjs",
    "configure-r2-json-cors": "node scripts/configure-r2-json-cors.mjs",
    "build-rtu-picture-manifest": "node scripts/build-rtu-picture-manifest.mjs",
    "reset-rtu-pictures": "node scripts/reset-rtu-pictures-from-folder.mjs",
    "clear-rtu-pictures": "node scripts/clear-rtu-pictures.mjs",
    "build-rtu-documents-manifest": "node scripts/build-rtu-documents-manifest.mjs",
    "reconcile-rtu-picture-manifest": "node scripts/reconcile-rtu-picture-manifest.mjs",
    "report-rtu-picture-gaps": "node scripts/report-rtu-picture-manifest-gaps.mjs",
    "prune-r2-pictures": "node scripts/prune-r2-pictures-by-allowlist.mjs",
    "delete-rtu-pictures-from-list": "node scripts/delete-rtu-pictures-from-list.mjs",
    "upload-rtu-pictures-from-folder": "node scripts/upload-rtu-pictures-from-folder.mjs",
    "report-sync-status": "node scripts/report-sync-status.mjs",
    "push-live": "node scripts/push-live.mjs",
    "restore-point": "node scripts/restore-point.mjs"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.10",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.80.7",
    "exifr": "^7.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.4"
  }
}
